# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Google Gemini API key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated list of allowed CORS origins.
# In production (Render), set this to your Chrome extension's origin:
#   chrome-extension://YOUR_EXTENSION_ID
# For local development, leave as * to allow all origins.
ALLOWED_ORIGINS=*

# MongoDB connection URI — required for the Library feature.
# Get a free Atlas cluster at https://www.mongodb.com/atlas
# Leave unset to run without library persistence (app still works).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
